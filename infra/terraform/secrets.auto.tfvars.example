# Copy to secrets.auto.tfvars (gitignored) and fill in.
# Terraform auto-loads any *.auto.tfvars file. Keys here become Secret Manager
# secrets at:  ${service_name}-${environment}-<envvar-lowercased-with-dashes>
# and are mounted into the Cloud Run container as the named env vars.
secret_values = {
  ANDELA_MCP_GROQ_API_KEY   = ""        # required for the chat agent
  ANDELA_MCP_OPENAI_API_KEY = ""        # optional: Agents-SDK trace export
  ANDELA_MCP_REMOTE_TOKEN   = ""        # optional: bearer for order-mcp upstream
}
