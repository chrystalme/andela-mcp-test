# `make tf-up` auto-detects project_id (gcloud), project_number (gcloud projects describe),
# and github_repository (git remote get-url origin) and passes them via -var on the command
# line, so leave those out of this file — adding them here would override the auto-detection.
region        = "us-central1"
environment   = "dev"
min_instances = 0
max_instances = 3

env = {
  ANDELA_MCP_ENVIRONMENT = "dev"
  ANDELA_MCP_LOG_FORMAT  = "json"
  ANDELA_MCP_LLM_MODEL   = "openai/gpt-oss-120b"
}

# Map ENV_VAR_NAME -> Secret Manager secret name. Leave empty unless you've
# already created secrets out-of-band; `secret_values` (in secrets.auto.tfvars)
# auto-creates them.
secrets = {}

allow_unauthenticated = false
