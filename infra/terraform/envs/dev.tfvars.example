# `make tf-up` auto-detects project_id (gcloud), project_number (gcloud projects describe),
# and github_repository (git remote get-url origin) and passes them via -var on the command
# line, so they're omitted here — adding them would override the auto-detection.
region        = "us-central1"
environment   = "dev"
min_instances = 0
max_instances = 3

env = {
  ANDELA_MCP_ENVIRONMENT = "dev"
  ANDELA_MCP_LOG_FORMAT  = "json"
  ANDELA_MCP_LLM_MODEL   = "openai/gpt-oss-120b"
}

# ENV_VAR -> Secret Manager secret name. Naming follows the convention used by
# infra/scripts/bootstrap.sh: ${service_name}-${environment}-<envvar lowercased, _->->.
# bootstrap.sh creates/updates these from .env; CI's terraform apply only mounts them.
secrets = {
  ANDELA_MCP_GROQ_API_KEY   = "andela-mcp-dev-andela-mcp-groq-api-key"
  ANDELA_MCP_OPENAI_API_KEY = "andela-mcp-dev-andela-mcp-openai-api-key"
  # Uncomment after putting a value for ANDELA_MCP_REMOTE_TOKEN in .env and re-running
  # `make tf-up` so the secret exists in Secret Manager:
  # ANDELA_MCP_REMOTE_TOKEN = "andela-mcp-dev-andela-mcp-remote-token"
}

allow_unauthenticated = false
