ANDELA_MCP_ENVIRONMENT=local
ANDELA_MCP_LOG_LEVEL=INFO
ANDELA_MCP_LOG_FORMAT=console
ANDELA_MCP_PORT=8080

ANDELA_MCP_ANTHROPIC_API_KEY=
ANDELA_MCP_ANTHROPIC_MODEL=claude-opus-4-7

ANDELA_MCP_GCP_PROJECT_ID=

ANDELA_MCP_SERVERS_CONFIG_PATH=config/servers.json

# Bearer token for the order-mcp upstream (used by remote-mcp entry in servers.json)
ANDELA_MCP_REMOTE_TOKEN=
